# ===========================================================
# CORTES AI - Variaveis de ambiente
# Copie este arquivo para ".env" e preencha as chaves.
# Sem chaves, o app roda em MODO DEMO (gera dados simulados).
# ===========================================================

# Porta do servidor
PORT=4000

# --- Geracao de roteiro (escolha UM provedor) ---
# NXS = Claude local via gateway de assinatura (custo ZERO de API) — prioritario.
# Chave nxsC_ emitida pelo nxs-agents; base e o tunnel do servidor.
NXS_API_KEY=
NXS_BASE_URL=https://agents-api.nexusholding.xyz

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OU Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Clone de voz: ElevenLabs (https://elevenlabs.io/) ---
ELEVENLABS_API_KEY=
# Voz padrao (PT-BR ideal); modelo e voice_settings afinados p/ Reels.
ELEVENLABS_DEFAULT_VOICE=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.4
ELEVENLABS_SIMILARITY=0.8
ELEVENLABS_STYLE=0.25
ELEVENLABS_SPEAKER_BOOST=true

# --- Publicacao real multi-tenant: Ayrshare (https://www.ayrshare.com/) ---
AYRSHARE_API_KEY=
# URL publica onde os MP4 de /uploads ficam acessiveis (exigida p/ postar).
PUBLIC_BASE_URL=

# --- Avatar de baixo custo: Replicate + SadTalker (audio-driven) ---
REPLICATE_API_TOKEN=
# heygen | replicate-sadtalker | none (vazio = auto pelo que estiver configurado)
AVATAR_PROVIDER=

# --- Avatar / clone de rosto: HeyGen (https://www.heygen.com/) ---
HEYGEN_API_KEY=

# --- Edicao automatica (FFmpeg embutido via ffmpeg-static) ---
# Opcional: fonte das legendas queimadas (padrao: Arial do Windows).
CAPTION_FONT=

# --- B-roll: clipes de fundo via Pexels (https://www.pexels.com/api/) ---
PEXELS_API_KEY=

# --- Publicacao nas redes (cada plataforma exige OAuth/app aprovado) ---
IG_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
YT_ACCESS_TOKEN=

# Senha simples do painel (deixe vazio para nao exigir login)
APP_PASSWORD=

# --- Login via Firebase Auth (aprovacao manual pelo admin) ---
# Caminho do JSON do service account OU o proprio JSON (1 linha) p/ hosts.
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json
# E-mail do administrador (sempre aprovado; aprova os demais no painel).
ADMIN_EMAIL=admin@verzius.com
